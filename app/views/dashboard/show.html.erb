<% content_for :title, "Dashboard - StorePilot AI" %>

<% store_name = @store&.name.presence || @store&.shopify_domain || "StorePilot AI" %>
<% connected = @store&.active? %>

<div class="app-shell">
  <aside class="sidebar">
    <a class="brand" href="/" aria-label="StorePilot home">
      <span class="brand-mark">S</span>
      <span>StorePilot</span>
    </a>

    <nav class="nav-list" aria-label="Main navigation">
      <a class="nav-link active" href="/">
        <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M3 3h7v7H3zM14 3h7v7h-7zM3 14h7v7H3zM14 14h7v7h-7z"/></svg>
        Overview
      </a>
      <a class="nav-link" href="#sync-status">
        <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M12 3a9 9 0 0 1 8.6 6.4l-1.9.6A7 7 0 1 0 12 19v-3l5 4-5 4v-3A9 9 0 0 1 12 3Z"/></svg>
        Sync
      </a>
      <a class="nav-link" href="#store-summary">
        <svg aria-hidden="true" viewBox="0 0 24 24"><path d="m12 2 9 5-9 5-9-5 9-5Zm-7 8.4 7 3.9 7-3.9V17l-7 3.9L5 17v-6.6Z"/></svg>
        Store
      </a>
      <a class="nav-link" href="#opportunities">
        <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M4 19h16v2H4v-2Zm1-3 4-4 3 3 7-8 1.5 1.3L12.1 18l-3-3-2.6 2.5L5 16Z"/></svg>
        Opportunities
      </a>
    </nav>

    <div class="sidebar-bottom">
      <div class="merchant">
        <span class="avatar"><%= store_name.first&.upcase || "S" %></span>
        <span><strong><%= store_name %></strong><small><%= @store&.shopify_domain || "No store connected" %></small></span>
      </div>
    </div>
  </aside>

  <main class="main-content">
    <header class="topbar">
      <div>
        <p class="eyebrow">Store dashboard</p>
        <h1><%= store_name %></h1>
      </div>
      <div class="top-actions">
        <span class="status-pill <%= connected ? "connected" : "disconnected" %>"><%= connected ? "Connected" : "Not connected" %></span>
        <%= form_with url: dashboard_sync_path, method: :post, class: "sync-form", local: true do %>
          <%= button_tag type: "submit", class: "primary-button sync-button", disabled: !connected do %>
            <span aria-hidden="true">↻</span>Run sync
          <% end %>
        <% end %>
      </div>
    </header>

    <% if flash[:notice].present? || flash[:alert].present? %>
      <section class="flash-banner <%= flash[:alert].present? ? "alert" : "notice" %>">
        <p><%= flash[:notice].presence || flash[:alert] %></p>
      </section>
    <% end %>

    <section class="ai-brief" id="sync-status">
      <div class="ai-icon">
        <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M12 2a10 10 0 1 1-7.1 2.9A10 10 0 0 1 12 2Zm1 5h-2v6l5 3 1-1.7-4-2.3V7Z"/></svg>
      </div>
      <div class="brief-copy">
        <span class="ai-label">SYNC STATUS</span>
        <h2>Last sync: <%= @last_sync_at ? l(@last_sync_at, format: :short) : "Not synced yet" %></h2>
        <p>
          <% if @last_sync_at.present? %>
            StorePilot has Shopify product or order data available for this store.
          <% else %>
            Connect Shopify and run the first sync to populate the dashboard.
          <% end %>
        </p>
      </div>
    </section>

    <% if @last_sync_at.blank? %>
      <section class="empty-state" aria-label="Empty dashboard state">
        <div>
          <span class="empty-icon">i</span>
          <h2>No sync data yet</h2>
          <p>After the first Shopify sync, this dashboard will show product, order, revenue, and inventory signals.</p>
        </div>
      </section>
    <% end %>

    <% if @store.present? %>
      <section class="panel ai-chat-panel" id="ai-store-manager" aria-label="AI Store Manager">
        <div class="panel-heading">
          <div><h2>AI Store Manager</h2><p>Ask about store performance, products, inventory, or revenue opportunities</p></div>
        </div>
        <div class="ai-chat-body">
          <% if @ai_messages.any? %>
            <div class="ai-message-list">
              <% @ai_messages.each do |message| %>
                <div class="ai-message <%= message.role %>">
                  <strong><%= message.role.titleize %></strong>
                  <p><%= message.content %></p>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="empty-state compact">
              <h3>No conversation yet</h3>
              <p>Ask the AI Store Manager a question to start a conversation.</p>
            </div>
          <% end %>
          <%= form_with url: dashboard_ai_chat_path, method: :post, class: "ai-chat-form", local: true do |form| %>
            <%= form.text_area :question, rows: 3, placeholder: "Ask what to fix first, why sales are down, or which products to promote.", aria: { label: "Ask AI Store Manager" } %>
            <%= form.submit "Ask", class: "primary-button", data: { loading_text: "Thinking..." } %>
          <% end %>
        </div>
      </section>
    <% end %>

    <% if @metrics.any? %>
      <section class="metrics-grid" id="store-summary" aria-label="Store summary">
        <% @metrics.each do |metric| %>
          <article class="metric-card">
            <div class="metric-heading"><span><%= metric[:label] %></span></div>
            <strong><%= metric[:value] %></strong>
          </article>
        <% end %>
      </section>
    <% end %>

    <section class="opportunity-section" id="opportunities" aria-label="Opportunity dashboard">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Opportunity engine</p>
          <h2>Store health</h2>
        </div>
        <% if @selected_audit_run&.overall_score.present? %>
          <strong class="score-badge"><%= @selected_audit_run.overall_score %>/100</strong>
        <% end %>
      </div>

      <% if @selected_audit_run.blank? %>
        <div class="empty-state compact">
          <h3>No audit yet</h3>
          <p>After the first audit runs, prioritized revenue, SEO, inventory, and product quality opportunities will appear here.</p>
        </div>
      <% elsif @selected_audit_run.status == "running" %>
        <div class="empty-state compact">
          <h3>Audit running</h3>
          <p>StorePilot is reviewing the latest synced store data. Opportunities will update when the audit finishes.</p>
        </div>
      <% else %>
        <% if @selected_audit_run != @latest_audit_run %>
          <div class="flash-banner notice"><p>Viewing audit from <%= l(@selected_audit_run.started_at, format: :short) %>.</p></div>
        <% else %>
          <div class="flash-banner notice"><p>Latest audit highlighted.</p></div>
        <% end %>
        <div class="metrics-grid category-score-grid">
          <% @category_scores.each do |category, score| %>
            <article class="metric-card">
              <div class="metric-heading"><span><%= category.to_s.humanize %></span></div>
              <strong><%= score %>/100</strong>
            </article>
          <% end %>
          <article class="metric-card">
            <div class="metric-heading"><span>Opportunities found</span></div>
            <strong><%= @opportunities.size %></strong>
          </article>
        </div>

        <section class="panel revenue-opportunities" aria-label="Revenue opportunities">
          <div class="panel-heading">
            <div><h3>Revenue opportunities</h3><p>Prioritized actions from sales, customer, inventory, and pricing signals</p></div>
          </div>
          <% if @revenue_opportunities.empty? %>
            <div class="empty-state compact">
              <h3>No revenue opportunities</h3>
              <p>The latest audit did not find revenue opportunities in the synced data.</p>
            </div>
          <% else %>
            <div class="attention-list">
              <% @revenue_opportunities.each do |result| %>
                <div class="attention-item opportunity-item">
                  <span class="status-icon <%= result.priority == "high" ? "warning" : "info" %>"><%= result.priority&.first&.upcase || "R" %></span>
                  <div>
                    <strong><%= result.title %></strong>
                    <p><%= result.ai_recommendation.presence || result.recommendation.presence || result.description %></p>
                    <% affected_products = Array(result.details["affected_product_ids"]).first(3) %>
                    <% affected_customers = Array(result.details["affected_customer_ids"]).first(3) %>
                    <% if affected_products.any? %>
                      <small>Affected products: <%= affected_products.join(", ") %></small>
                    <% elsif affected_customers.any? %>
                      <small>Affected customers: <%= affected_customers.join(", ") %></small>
                    <% end %>
                    <% if result.rule_key == "top_customer_silence" %>
                      <%= button_to "Generate win-back draft", dashboard_win_back_email_draft_path(result), method: :post, class: "primary-button draft-button" %>
                      <% if result.win_back_email_draft.present? %>
                        <textarea class="email-draft" readonly rows="8"><%= result.win_back_email_draft %></textarea>
                      <% end %>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          <% end %>
        </section>

        <% if @opportunities.empty? %>
          <div class="empty-state compact">
            <h3>No open opportunities</h3>
            <p>The latest audit did not find prioritized opportunities in the synced data.</p>
          </div>
        <% else %>
          <div class="opportunity-groups">
            <% %w[high medium low].each do |priority| %>
              <% results = @opportunities_by_priority.fetch(priority, []) %>
              <% next if results.empty? %>
              <article class="panel opportunity-group">
                <div class="panel-heading">
                  <div><h3><%= priority.titleize %> priority</h3><p><%= pluralize(results.size, "opportunity") %></p></div>
                </div>
                <div class="attention-list">
                  <% results.each do |result| %>
                    <div class="attention-item opportunity-item">
                      <span class="status-icon <%= priority == "high" ? "warning" : "info" %>"><%= result.impact&.first&.upcase || "O" %></span>
                      <div>
                        <strong><%= result.title %></strong>
                        <p><%= result.ai_recommendation.presence || result.recommendation.presence || result.description %></p>
                        <% affected_products = Array(result.details["affected_product_ids"]).first(3) %>
                        <% if affected_products.any? %>
                          <small>Affected products: <%= affected_products.join(", ") %></small>
                        <% end %>
                        <% if result.rule_key == "repeat_buyer_analysis" && result.details["trend"].present? %>
                          <% trend = result.details.fetch("trend") %>
                          <small>Repeat buyer trend: <%= number_to_percentage(trend.fetch("repeat_buyer_ratio_delta").to_f * 100, precision: 0) %></small>
                        <% end %>
                      </div>
                    </div>
                  <% end %>
                </div>
              </article>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </section>

    <% if @audit_runs.any? %>
      <section class="panel audit-history" aria-label="Audit history">
        <div class="panel-heading">
          <div><h2>Audit history</h2><p>Previous runs and score changes</p></div>
        </div>
        <div class="attention-list">
          <% @audit_runs.each do |audit_run| %>
            <%= link_to dashboard_path(audit_run_id: audit_run.id), class: "attention-item opportunity-item #{audit_run == @latest_audit_run ? 'latest-audit' : ''}" do %>
              <span class="status-icon <%= audit_run == @latest_audit_run ? "info" : "warning" %>"><%= audit_run.overall_score || "-" %></span>
              <div>
                <strong><%= audit_run == @latest_audit_run ? "Latest audit" : "Previous audit" %></strong>
                <p><%= l(audit_run.started_at, format: :short) %> · <%= audit_run.status.humanize %></p>
                <% if audit_run.previous_score_delta.present? %>
                  <small>Score trend: <%= audit_run.previous_score_delta.positive? ? "+" : "" %><%= audit_run.previous_score_delta %></small>
                <% else %>
                  <small>Score trend: baseline</small>
                <% end %>
              </div>
            <% end %>
          <% end %>
        </div>
      </section>
    <% end %>

    <section class="dashboard-grid">
      <article class="panel store-panel">
        <div class="panel-heading">
          <div><h2>Store connection</h2><p>Current Shopify account state</p></div>
        </div>
        <dl class="detail-list">
          <div><dt>Store</dt><dd><%= store_name %></dd></div>
          <div><dt>Domain</dt><dd><%= @store&.shopify_domain || "Not connected" %></dd></div>
          <div><dt>Status</dt><dd><%= connected ? "Connected" : "Not connected" %></dd></div>
          <div><dt>Last sync</dt><dd><%= @last_sync_at ? l(@last_sync_at, format: :short) : "Not synced yet" %></dd></div>
        </dl>
      </article>

      <article class="panel attention-panel">
        <div class="panel-heading">
          <div><h2>Next up</h2><p>Data foundation status</p></div>
        </div>
        <div class="attention-list">
          <div class="attention-item">
            <span class="status-icon <%= @store.present? ? "info" : "warning" %>"><%= @store.present? ? "OK" : "!" %></span>
            <div><strong>Shopify store</strong><p><%= @store.present? ? "Store record exists" : "No store record found" %></p></div>
          </div>
          <div class="attention-item">
            <span class="status-icon <%= @last_sync_at.present? ? "info" : "warning" %>"><%= @last_sync_at.present? ? "OK" : "!" %></span>
            <div><strong>Initial sync</strong><p><%= @last_sync_at.present? ? "Dashboard data is available" : "Waiting for products or orders" %></p></div>
          </div>
          <% @ai_conversations.each do |conversation| %>
            <div class="attention-item">
              <span class="status-icon info">AI</span>
              <div><strong><%= conversation.title %></strong><p><%= pluralize(conversation.ai_messages.size, "message") %></p></div>
            </div>
          <% end %>
        </div>
      </article>
    </section>
  </main>
</div>
