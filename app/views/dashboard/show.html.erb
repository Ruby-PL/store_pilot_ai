<% content_for :title, "Dashboard - StorePilot AI" %>

<% store_name = @store&.name.presence || @store&.shopify_domain || "StorePilot AI" %>
<% connected = @store&.active? %>

<div class="app-shell">
  <aside class="sidebar">
    <a class="brand" href="/" aria-label="StorePilot home">
      <span class="brand-mark">S</span>
      <span>StorePilot</span>
    </a>

    <nav class="nav-list" aria-label="Main navigation">
      <a class="nav-link active" href="/">
        <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M3 3h7v7H3zM14 3h7v7h-7zM3 14h7v7H3zM14 14h7v7h-7z"/></svg>
        Overview
      </a>
      <a class="nav-link" href="#sync-status">
        <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M12 3a9 9 0 0 1 8.6 6.4l-1.9.6A7 7 0 1 0 12 19v-3l5 4-5 4v-3A9 9 0 0 1 12 3Z"/></svg>
        Sync
      </a>
      <a class="nav-link" href="#store-summary">
        <svg aria-hidden="true" viewBox="0 0 24 24"><path d="m12 2 9 5-9 5-9-5 9-5Zm-7 8.4 7 3.9 7-3.9V17l-7 3.9L5 17v-6.6Z"/></svg>
        Store
      </a>
    </nav>

    <div class="sidebar-bottom">
      <div class="merchant">
        <span class="avatar"><%= store_name.first&.upcase || "S" %></span>
        <span><strong><%= store_name %></strong><small><%= @store&.shopify_domain || "No store connected" %></small></span>
      </div>
    </div>
  </aside>

  <main class="main-content">
    <header class="topbar">
      <div>
        <p class="eyebrow">Store dashboard</p>
        <h1><%= store_name %></h1>
      </div>
      <div class="top-actions">
        <span class="status-pill <%= connected ? "connected" : "disconnected" %>"><%= connected ? "Connected" : "Not connected" %></span>
        <%= form_with url: dashboard_sync_path, method: :post, class: "sync-form", local: true do %>
          <%= button_tag type: "submit", class: "primary-button sync-button", disabled: !connected do %>
            <span aria-hidden="true">↻</span>Run sync
          <% end %>
        <% end %>
      </div>
    </header>

    <% if flash[:notice].present? || flash[:alert].present? %>
      <section class="flash-banner <%= flash[:alert].present? ? "alert" : "notice" %>">
        <p><%= flash[:notice].presence || flash[:alert] %></p>
      </section>
    <% end %>

    <section class="ai-brief" id="sync-status">
      <div class="ai-icon">
        <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M12 2a10 10 0 1 1-7.1 2.9A10 10 0 0 1 12 2Zm1 5h-2v6l5 3 1-1.7-4-2.3V7Z"/></svg>
      </div>
      <div class="brief-copy">
        <span class="ai-label">SYNC STATUS</span>
        <h2>Last sync: <%= @last_sync_at ? l(@last_sync_at, format: :short) : "Not synced yet" %></h2>
        <p>
          <% if @last_sync_at.present? %>
            StorePilot has Shopify product or order data available for this store.
          <% else %>
            Connect Shopify and run the first sync to populate the dashboard.
          <% end %>
        </p>
      </div>
    </section>

    <% if @last_sync_at.blank? %>
      <section class="empty-state" aria-label="Empty dashboard state">
        <div>
          <span class="empty-icon">i</span>
          <h2>No sync data yet</h2>
          <p>After the first Shopify sync, this dashboard will show product, order, revenue, and inventory signals.</p>
        </div>
      </section>
    <% end %>

    <% if @metrics.any? %>
      <section class="metrics-grid" id="store-summary" aria-label="Store summary">
        <% @metrics.each do |metric| %>
          <article class="metric-card">
            <div class="metric-heading"><span><%= metric[:label] %></span></div>
            <strong><%= metric[:value] %></strong>
          </article>
        <% end %>
      </section>
    <% end %>

    <section class="dashboard-grid">
      <article class="panel store-panel">
        <div class="panel-heading">
          <div><h2>Store connection</h2><p>Current Shopify account state</p></div>
        </div>
        <dl class="detail-list">
          <div><dt>Store</dt><dd><%= store_name %></dd></div>
          <div><dt>Domain</dt><dd><%= @store&.shopify_domain || "Not connected" %></dd></div>
          <div><dt>Status</dt><dd><%= connected ? "Connected" : "Not connected" %></dd></div>
          <div><dt>Last sync</dt><dd><%= @last_sync_at ? l(@last_sync_at, format: :short) : "Not synced yet" %></dd></div>
        </dl>
      </article>

      <article class="panel attention-panel">
        <div class="panel-heading">
          <div><h2>Next up</h2><p>Data foundation status</p></div>
        </div>
        <div class="attention-list">
          <div class="attention-item">
            <span class="status-icon <%= @store.present? ? "info" : "warning" %>"><%= @store.present? ? "OK" : "!" %></span>
            <div><strong>Shopify store</strong><p><%= @store.present? ? "Store record exists" : "No store record found" %></p></div>
          </div>
          <div class="attention-item">
            <span class="status-icon <%= @last_sync_at.present? ? "info" : "warning" %>"><%= @last_sync_at.present? ? "OK" : "!" %></span>
            <div><strong>Initial sync</strong><p><%= @last_sync_at.present? ? "Dashboard data is available" : "Waiting for products or orders" %></p></div>
          </div>
        </div>
      </article>
    </section>
  </main>
</div>
