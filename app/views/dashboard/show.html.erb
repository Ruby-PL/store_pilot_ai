<% content_for :title, "Dashboard - StorePilot AI" %>

<% store_name = @store&.name.presence || @store&.shopify_domain || "StorePilot AI" %>
<% connected = @store&.active? %>
<% section_path = ->(name) { dashboard_path(section: name, audit_run_id: @selected_audit_run&.id) } %>
<% hero_opportunity = @priority_opportunities.first || @hero_opportunity %>
<% hero_amount = @hero_amount || "€240" %>

<div class="app-shell advisor-shell">
  <aside class="sidebar">
    <a class="brand" href="<%= section_path.call("today") %>" aria-label="StorePilot home">
      <span class="brand-mark">S</span>
      <span>StorePilot</span>
    </a>

    <div class="sidebar-label">Advisor</div>
    <nav class="nav-list" aria-label="Main navigation">
      <a class="nav-link <%= @dashboard_section == "today" ? "active" : "" %>" href="<%= section_path.call("today") %>"><span class="nav-dot"></span>Today</a>
      <a class="nav-link <%= @dashboard_section == "opportunities" ? "active" : "" %>" href="<%= section_path.call("opportunities") %>"><span class="nav-dot"></span>Opportunities</a>
      <a class="nav-link <%= @dashboard_section == "store" ? "active" : "" %>" href="<%= section_path.call("store") %>"><span class="nav-dot"></span>Store</a>
      <a class="nav-link <%= @dashboard_section == "activity" ? "active" : "" %>" href="<%= section_path.call("activity") %>"><span class="nav-dot"></span>Activity</a>
    </nav>

    <div class="sidebar-bottom">
      <div class="merchant">
        <span class="avatar"><%= store_name.first&.upcase || "S" %></span>
        <span>
          <strong><%= store_name %></strong>
          <small><%= @store&.shopify_domain || "No store connected" %></small>
        </span>
      </div>
    </div>
  </aside>

  <main class="main-content">
    <header class="topbar">
      <div>
        <p class="eyebrow">StorePilot · <%= @store&.shopify_domain.presence || "Merchant workspace" %></p>
        <h1>Store advisor</h1>
      </div>
      <div class="top-actions">
        <span class="status-pill <%= connected ? "connected" : "disconnected" %>">
          <%= connected ? "Connected · synced #{(@last_sync_at ? l(@last_sync_at, format: :short) : "not yet")}" : "Not connected" %>
        </span>
        <%= form_with url: dashboard_sync_path, method: :post, class: "sync-form", local: true do %>
          <%= button_tag type: "submit", class: "primary-button sync-button", disabled: !connected do %>
            <span aria-hidden="true">↻</span>Run sync
          <% end %>
        <% end %>
      </div>
    </header>

    <% if flash[:notice].present? || flash[:alert].present? %>
      <section class="flash-banner <%= flash[:alert].present? ? "alert" : "notice" %>">
        <p><%= flash[:notice].presence || flash[:alert] %></p>
      </section>
    <% end %>

    <div class="dashboard-column">
      <% case @dashboard_section %>
      <% when "today" %>
        <section class="hero-spotlight">
          <div class="hero-spotlight-copy">
            <div class="hero-kicker">StorePilot advises</div>
            <h2>Three moves this week. Start with the first.</h2>
            <p>
              <% if hero_opportunity.present? %>
                <%= hero_opportunity.ai_recommendation.presence || hero_opportunity.recommendation.presence || "StorePilot has found the most important opportunity and turned it into a clear next step." %>
              <% else %>
                StorePilot is ready to turn synced data into clear next steps once the next audit finishes.
              <% end %>
            </p>
          </div>
        </section>

        <div class="section-heading">
          <div>
            <h2>Today's priorities</h2>
            <p>Ranked by impact</p>
          </div>
          <span class="section-hint">Ranked by impact</span>
        </div>

        <% if @priority_opportunities.empty? %>
          <div class="empty-state">
            <h3>No priorities yet</h3>
            <p>Run sync and audit to populate today’s work list.</p>
          </div>
        <% else %>
          <div class="priority-stack">
            <% @priority_opportunities.each_with_index do |result, index| %>
              <article class="priority-card">
                <div class="priority-number"><%= index + 1 %></div>
                <div class="priority-body">
                  <div class="priority-badge <%= result.priority == "high" ? "high" : result.priority == "medium" ? "medium" : "low" %>"><%= result.priority.to_s.humanize.presence || "Priority" %></div>
                  <h3><%= result.title %></h3>
                  <p><strong>Why it matters:</strong> <%= result.description.presence || result.recommendation.presence || "This opportunity came from the latest audit." %></p>
                  <p><strong>Do this:</strong> <%= result.ai_recommendation.presence || result.recommendation.presence || "Review the action and decide the next step." %></p>
                </div>
                <div class="priority-side">
                  <strong><%= opportunity_amount(result) || "Review" %></strong>
                  <small><%= result.category.to_s.humanize.presence || "recoverable" %></small>
                  <% if result.rule_key == "top_customer_silence" %>
                    <%= button_to "Open", dashboard_win_back_email_draft_path(result), method: :post, class: "secondary-button" %>
                  <% elsif result.rule_key == "bundle_opportunity" %>
                    <span class="secondary-button static">Create bundle</span>
                  <% elsif result.rule_key == "dead_stock" %>
                    <span class="secondary-button static">Review stock</span>
                  <% else %>
                    <span class="secondary-button static">Review</span>
                  <% end %>
                </div>
              </article>
            <% end %>
          </div>
        <% end %>

        <section class="panel ask-panel" aria-label="Ask StorePilot">
          <div class="panel-heading">
            <div>
              <h3>Ask StorePilot</h3>
              <p>It already knows your products, orders, inventory and audits.</p>
            </div>
          </div>
          <div class="ask-panel-body">
            <%= form_with url: dashboard_ai_chat_path, method: :post, class: "ai-chat-form", local: true do |form| %>
              <%= hidden_field_tag :ai_conversation_id, @ai_conversation&.id %>
              <%= form.text_area :question, rows: 3, placeholder: "Ask why sales are down, what to fix first, or which products to promote...", aria: { label: "Ask StorePilot" } %>
              <%= form.submit "Ask", class: "primary-button" %>
            <% end %>
            <div class="prompt-chips">
              <span>Why are sales down?</span>
              <span>What should I fix first?</span>
              <span>Which products to promote?</span>
            </div>
            <% if @ai_conversation.present? %>
              <div class="ask-answer">
                <div class="ask-answer-label">Conversation</div>
                <p><%= @ai_conversation.title %></p>
              </div>
            <% end %>
            <% if @ai_messages.any? %>
              <% last_assistant = @ai_messages.select { |message| message.role == "assistant" }.last %>
              <% if last_assistant.present? %>
                <div class="ask-answer">
                  <div class="ask-answer-label">Last answer</div>
                  <p><%= last_assistant.content %></p>
                </div>
              <% end %>
            <% end %>
          </div>
        </section>

        <div class="section-heading numbers-heading">
          <div>
            <h2>The numbers behind it</h2>
            <p>Store health and usage in one view</p>
          </div>
          <span class="section-hint">Summary</span>
        </div>
        <section class="metrics-grid today-metrics" aria-label="Store summary">
          <% @metrics.each do |metric| %>
            <article class="metric-card">
              <div class="metric-heading"><span><%= metric[:label] %></span></div>
              <strong><%= metric[:value] %></strong>
            </article>
          <% end %>
          <article class="metric-card">
            <div class="metric-heading"><span>Health</span></div>
            <strong><%= @selected_audit_run&.overall_score ? "#{@selected_audit_run.overall_score}/100" : "—" %></strong>
            <p class="metric-note"><%= @selected_audit_run&.previous_score_delta ? "#{@selected_audit_run.previous_score_delta.positive? ? "↑" : "↓"} #{@selected_audit_run.previous_score_delta.abs}" : "baseline" %></p>
          </article>
        </section>

      <% when "opportunities" %>
        <section class="opportunity-hero">
          <div class="opportunity-hero-copy">
            <div class="hero-kicker">High priority · revenue opportunity</div>
            <h2><%= hero_opportunity&.title || "No opportunity yet" %></h2>
            <p><%= hero_opportunity&.ai_recommendation.presence || hero_opportunity&.recommendation.presence || "StorePilot will explain the highest impact opportunity here once the audit finishes." %></p>
          </div>
          <aside class="recoverable-card">
            <div class="recoverable-label">Recoverable</div>
            <strong><%= hero_amount %></strong>
            <p><%= hero_opportunity&.description.presence || "Estimated at-risk revenue from the top opportunity." %></p>
            <% if hero_opportunity&.rule_key == "top_customer_silence" %>
              <%= button_to "Generate win-back draft", dashboard_win_back_email_draft_path(hero_opportunity), method: :post, class: "secondary-button" %>
            <% else %>
              <span class="secondary-button static">Open</span>
            <% end %>
          </aside>
        </section>

        <% if @priority_opportunities.any? %>
        <section class="panel" aria-label="Opportunity cards">
            <div class="panel-heading">
              <div>
                <h3>Today's opportunities</h3>
                <p>Ranked by impact</p>
              </div>
              <span class="section-hint">Open</span>
            </div>
            <div class="attention-list">
              <% @priority_opportunities.each do |result| %>
                <div class="attention-item opportunity-item">
                  <span class="status-icon <%= result.priority == "high" ? "warning" : "info" %>"><%= result.priority.to_s.first&.upcase || "O" %></span>
                  <div>
                    <strong><%= result.title %></strong>
                    <p><span class="opportunity-label">What this means</span> <%= result.description.presence || result.recommendation.presence || "Audit result detected." %></p>
                    <p><span class="opportunity-label">What to do</span> <%= result.ai_recommendation.presence || result.recommendation.presence || "Review the opportunity and choose the highest-impact next step." %></p>
                    <% if result.rule_key == "bundle_opportunity" && Array(result.details["bundle_pairs"]).any? %>
                      <% bundle_examples = Array(result.details["bundle_pairs"]).first(2).map do |pair| %>
                        <% product_names = Array(pair["product_ids"]).map { |product_id| @store_product_titles.fetch(product_id, product_id) } %>
                        <% "#{product_names.join(' + ')} (#{pair['frequency']} orders)" %>
                      <% end %>
                      <% if bundle_examples.any? %>
                        <small>Example bundles: <%= bundle_examples.join(" | ") %></small>
                      <% end %>
                    <% end %>
                    <% if result.rule_key == "repeat_buyer_analysis" && result.details["trend"].present? %>
                      <% trend = result.details.fetch("trend") %>
                      <small>Repeat buyer trend: <%= number_to_percentage(trend.fetch("repeat_buyer_ratio_delta").to_f * 100, precision: 0) %></small>
                    <% end %>
                    <% examples = result.details["examples"] %>
                    <% if examples.present? && Array(examples["items"]).any? %>
                      <% applied = result.details["applied"] %>
                      <% apply_supported = %w[seo_gap product_quality].include?(result.rule_key) %>
                      <div class="audit-examples">
                        <div class="audit-examples-head">
                          <p class="audit-examples-label"><%= examples["label"].presence || "Examples you could use" %></p>
                          <% if applied.present? %>
                            <span class="applied-badge">Applied to <%= applied["count"] %> in Shopify</span>
                          <% end %>
                        </div>
                        <% if apply_supported %>
                          <%= form_with url: dashboard_apply_audit_result_path(result), method: :post, class: "apply-form", local: true do %>
                            <ul>
                              <% Array(examples["items"]).each_with_index do |item, index| %>
                                <li>
                                  <strong><%= item["title"] %></strong>
                                  <%= hidden_field_tag "apply[#{index}][product_id]", item["product_id"] %>
                                  <% Array(item["fields"]).each do |field| %>
                                    <label class="apply-field">
                                      <em><%= field["label"] %></em>
                                      <% if field["key"].to_s.include?("description") %>
                                        <%= text_area_tag "apply[#{index}][#{field["key"]}]", field["value"], rows: 2 %>
                                      <% else %>
                                        <%= text_field_tag "apply[#{index}][#{field["key"]}]", field["value"] %>
                                      <% end %>
                                    </label>
                                  <% end %>
                                </li>
                              <% end %>
                            </ul>
                            <div class="apply-actions">
                              <%= submit_tag "Apply to Shopify", class: "primary-button" %>
                              <small>Edit any value first. Nothing changes in Shopify until you click.</small>
                            </div>
                          <% end %>
                        <% else %>
                          <ul>
                            <% Array(examples["items"]).each do |item| %>
                              <li>
                                <strong><%= item["title"] %></strong>
                                <% Array(item["fields"]).each do |field| %>
                                  <span><em><%= field["label"] %></em> <%= field["value"] %></span>
                                <% end %>
                              </li>
                            <% end %>
                          </ul>
                        <% end %>
                      </div>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          </section>
        <% end %>

        <div class="opportunity-layout">
          <section class="panel" aria-label="What's happening">
            <div class="panel-heading">
              <div>
                <h3>What's happening</h3>
                <p>The audit compresses the signal into a few concrete examples.</p>
              </div>
            </div>
            <div class="attention-list">
              <% Array(hero_opportunity&.details&.fetch("affected_customer_ids", [])).first(3).each do |customer_id| %>
                <div class="attention-item">
                  <span class="status-icon info">AI</span>
                  <div>
                    <strong><%= customer_id %></strong>
                    <p><%= hero_opportunity&.rule_key == "top_customer_silence" ? "Slowed after recent inactivity" : "Linked to the selected opportunity" %></p>
                  </div>
                </div>
              <% end %>
              <% Array(hero_opportunity&.details&.fetch("affected_product_ids", [])).first(3).each do |product_id| %>
                <div class="attention-item">
                  <span class="status-icon info">PR</span>
                  <div>
                    <strong><%= @store_product_titles.fetch(product_id, product_id) %></strong>
                    <p>Shown in the latest audit</p>
                  </div>
                </div>
              <% end %>
            </div>
          </section>

          <section class="panel" aria-label="Why it matters">
            <div class="panel-heading">
              <div>
                <h3>Why it matters</h3>
                <p>Explain the business impact in plain language.</p>
              </div>
            </div>
            <div class="panel-body copy-panel">
              <p><%= hero_opportunity&.description.presence || "This item is worth attention because it affects revenue, conversion, or operational efficiency." %></p>
            </div>
          </section>

          <section class="panel" aria-label="Recommended action">
            <div class="panel-heading">
              <div>
                <h3>Recommended action</h3>
                <p>One clear thing to do next.</p>
              </div>
            </div>
            <div class="panel-body copy-panel">
              <% if hero_opportunity.present? %>
                <ol class="step-list">
                  <li><%= hero_opportunity.ai_recommendation.presence || hero_opportunity.recommendation.presence || "Review the opportunity." %></li>
                  <li>Mark the action complete once it is done.</li>
                  <li>Check Activity to see what changed after the next audit.</li>
                </ol>
              <% else %>
                <p>Run an audit to generate prioritized recommendations here.</p>
              <% end %>
            </div>
          </section>
        </div>

        <section class="panel score-panel" aria-label="Category scores">
          <div class="panel-heading">
            <div>
              <h3>Category scores</h3>
              <p>Ranked by the latest audit</p>
            </div>
          </div>
          <div class="score-grid">
            <% @category_scores.each do |category, score| %>
              <div class="score-row">
                <span><%= category.to_s.humanize %></span>
                <strong><%= score %></strong>
              </div>
            <% end %>
          </div>
        </section>

        <% if hero_opportunity&.win_back_email_draft.present? %>
          <section class="panel" aria-label="Win-back draft">
            <div class="panel-heading">
              <div>
                <h3>Win-back draft</h3>
                <p>Generated from the selected opportunity.</p>
              </div>
            </div>
            <div class="panel-body">
              <textarea class="email-draft" readonly><%= hero_opportunity.win_back_email_draft %></textarea>
            </div>
          </section>
        <% end %>

      <% when "store" %>
        <section class="store-hero">
          <div>
            <p class="eyebrow">Connection & foundation</p>
            <h2>Your store</h2>
            <p>Everything StorePilot reads to advise you. When these are green, the advice is trustworthy.</p>
          </div>
        </section>

        <div class="store-top-grid">
          <section class="panel" aria-label="Store connection">
            <div class="panel-heading">
              <div>
                <h3>Store connection</h3>
              </div>
            </div>
            <dl class="detail-list compact-list">
              <div><dt>Store</dt><dd><%= store_name %></dd></div>
              <div><dt>Domain</dt><dd><%= @store&.shopify_domain || "Not connected" %></dd></div>
              <div><dt>Status</dt><dd><%= connected ? "Connected" : "Not connected" %></dd></div>
              <div><dt>Last sync</dt><dd><%= @last_sync_at ? l(@last_sync_at, format: :short) : "Not synced yet" %></dd></div>
            </dl>
          </section>

          <aside class="usage-card usage-card-dark" aria-label="AI usage">
            <div class="usage-card-header">
              <div>
                <h3>AI usage</h3>
                <p><%= @ai_plan.presence || "Free plan" %></p>
              </div>
              <span class="usage-badge"><%= @ai_usage_summary || "0/25" %></span>
            </div>
            <div class="usage-stat">
              <strong><%= @ai_requests_remaining || 0 %></strong>
              <span>questions left this month</span>
            </div>
            <div class="usage-bar" aria-hidden="true">
              <% usage_limit = @store&.ai_request_limit.to_i %>
              <% usage_used = @store&.ai_requests_count_current_month.to_i %>
              <% usage_ratio = usage_limit.positive? ? (usage_used.to_f / usage_limit * 100).round : 0 %>
              <span style="width: <%= [ usage_ratio, 100 ].min %>%"></span>
            </div>
            <p class="usage-note">The AI layer powers chat, explanations, and recommendation copy when the merchant asks for help.</p>
          </aside>
        </div>

        <section class="panel" aria-label="Data foundation">
          <div class="panel-heading">
            <div>
              <h3>Data foundation</h3>
              <p>Synced from Shopify</p>
            </div>
          </div>
          <div class="foundation-grid">
            <div class="foundation-card">
              <span class="foundation-mark">OK</span>
              <div>
                <strong>Shopify store</strong>
                <p>Record exists</p>
              </div>
            </div>
            <div class="foundation-card">
              <span class="foundation-mark">OK</span>
              <div>
                <strong>Initial sync</strong>
                <p>Data available</p>
              </div>
            </div>
            <div class="foundation-card">
              <span class="foundation-mark">OK</span>
              <div>
                <strong>Audit engine</strong>
                <p><%= @latest_audit_run.present? ? "Last run #{l(@latest_audit_run.started_at, format: :short)}" : "Waiting for first run" %></p>
              </div>
            </div>
          </div>
        </section>

        <div class="catalog-label">Catalog snapshot</div>
        <section class="catalog-grid" aria-label="Catalog snapshot">
          <% products_count = @store&.products_count.to_i %>
          <% orders_count = @store&.orders_count.to_i %>
          <% revenue_total = @store&.orders_total_price.to_f %>
          <% avg_order = orders_count.positive? ? format('%.2f', revenue_total / orders_count) : "—" %>
          <article class="catalog-card"><strong><%= products_count %></strong><span>Products</span></article>
          <article class="catalog-card"><strong><%= orders_count %></strong><span>Orders</span></article>
          <article class="catalog-card"><strong><%= format('%.2f', revenue_total) %></strong><span>Revenue</span></article>
          <article class="catalog-card"><strong><%= avg_order %></strong><span>Avg order</span></article>
        </section>

      <% when "activity" %>
        <section class="activity-hero">
          <div>
            <p class="eyebrow">History</p>
            <h2>Activity</h2>
            <p>Every audit, conversation, and action StorePilot has taken with you so you can see what changed and why.</p>
          </div>
        </section>

        <section class="metrics-grid activity-metrics" aria-label="Follow-up stats">
          <article class="metric-card"><div class="metric-heading"><span>Open actions</span></div><strong><%= @action_summary.fetch(:open_count, 0) %></strong></article>
          <article class="metric-card"><div class="metric-heading"><span>Completed actions</span></div><strong><%= @action_summary.fetch(:completed_count, 0) %></strong></article>
          <article class="metric-card"><div class="metric-heading"><span>Score trend</span></div><strong><%= @action_summary.fetch(:previous_score_delta, 0).to_i.positive? ? "+" : "" %><%= @action_summary.fetch(:previous_score_delta, 0).to_i %></strong></article>
        </section>

        <section class="panel" aria-label="Audit history">
          <div class="panel-heading">
            <div>
              <h3>Audit history</h3>
              <p>Health score over time</p>
            </div>
            <span class="section-hint">History</span>
          </div>
          <% if @activity_runs.any? %>
            <div class="history-sparkline">
              <% @activity_runs.reverse.each do |audit_run| %>
                <% bar_height = [[audit_run.overall_score.to_i, 20].max, 100].min %>
                <div class="spark-bar">
                  <div class="spark-fill <%= audit_run == @latest_audit_run ? "latest" : "" %>" style="height:<%= bar_height %>%"></div>
                  <span><%= audit_run.overall_score || "—" %></span>
                </div>
              <% end %>
            </div>
            <div class="attention-list">
              <% @activity_runs.each do |audit_run| %>
                <div class="attention-item">
                  <span class="status-icon <%= audit_run == @latest_audit_run ? "info" : "warning" %>"><%= audit_run.overall_score || "-" %></span>
                  <div>
                    <strong><%= audit_run == @latest_audit_run ? "Latest audit" : "Previous audit" %></strong>
                    <p><%= l(audit_run.started_at, format: :short) %> · <%= audit_run.status.humanize %></p>
                    <small><%= audit_run.previous_score_delta.present? ? "Score trend: #{audit_run.previous_score_delta.positive? ? "+" : ""}#{audit_run.previous_score_delta}" : "Score trend: baseline" %></small>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="empty-state compact">
              <h3>No audit history yet</h3>
              <p>Run the first sync and audit to populate the history view.</p>
            </div>
          <% end %>
        </section>

        <div class="activity-grid">
          <section class="panel" aria-label="Completed actions">
            <div class="panel-heading">
              <div>
                <h3>Completed actions</h3>
              </div>
              <span class="section-hint">Done</span>
            </div>
            <% if @completed_audit_actions.empty? %>
              <div class="empty-state compact">
                <h3>No completed actions yet</h3>
                <p>Mark an action done to see it move into the follow-up history.</p>
              </div>
            <% else %>
              <div class="attention-list">
                <% @completed_audit_actions.each do |action| %>
                  <div class="attention-item">
                    <span class="status-icon info">✓</span>
                    <div>
                      <strong><%= action.title %></strong>
                      <p><%= action.audit_result.ai_recommendation.presence || action.next_step %></p>
                      <% if action.merchant_note.present? %><small><%= action.merchant_note %></small><% end %>
                      <% if action.reference_url.present? %><small><%= action.reference_url %></small><% end %>
                    </div>
                  </div>
                <% end %>
              </div>
            <% end %>
          </section>

          <section class="panel" aria-label="AI conversations">
            <div class="panel-heading">
              <div>
                <h3>AI conversations</h3>
              </div>
              <span class="section-hint">Chat</span>
            </div>
            <% if @ai_conversations.any? %>
              <div class="conversation-list">
                <% @ai_conversations.each do |conversation| %>
                  <%= link_to dashboard_path(section: "activity", ai_conversation_id: conversation.id), class: "conversation-item" do %>
                    <span class="conversation-mark">AI</span>
                    <div>
                      <strong><%= conversation.title %></strong>
                      <p><%= pluralize(conversation.ai_messages.size, "message") %></p>
                    </div>
                    <span class="conversation-chevron">›</span>
                  <% end %>
                <% end %>
              </div>
            <% else %>
              <div class="empty-state compact">
                <h3>No conversations yet</h3>
                <p>Ask the AI Store Manager a question to start a conversation.</p>
              </div>
            <% end %>
          </section>
        </div>

        <section class="panel action-center-panel" aria-label="Action center">
          <div class="panel-heading">
            <div>
              <h3>Action center</h3>
              <p>Track the concrete work items from the latest audit.</p>
            </div>
            <small><%= pluralize(@open_audit_actions.size, "open action") %> · <%= pluralize(@completed_audit_actions.size, "completed") %></small>
          </div>
          <% if @open_audit_actions.empty? %>
            <div class="empty-state compact">
              <h3>No open actions</h3>
              <p>The current audit has no unfinished actions.</p>
            </div>
          <% else %>
            <div class="attention-list">
              <% @open_audit_actions.each do |action| %>
                <div class="attention-item opportunity-item">
                  <span class="status-icon info">TO</span>
                  <%= form_with url: dashboard_audit_action_path(action), method: :patch, class: "audit-action-form", local: true do %>
                    <div>
                      <strong><%= action.title %></strong>
                      <p><span class="opportunity-label">Next step</span> <%= action.audit_result.ai_recommendation.presence || action.next_step %></p>
                      <div class="audit-action-fields">
                        <div class="field">
                          <label for="<%= dom_id(action, :note) %>">Note</label>
                          <%= text_area_tag :merchant_note, action.merchant_note, id: dom_id(action, :note), rows: 2, placeholder: "What did you try or decide?" %>
                        </div>
                        <div class="field">
                          <label for="<%= dom_id(action, :reference_url) %>">Reference link</label>
                          <%= text_field_tag :reference_url, action.reference_url, id: dom_id(action, :reference_url), placeholder: "https://..." %>
                        </div>
                      </div>
                      <div class="audit-action-buttons">
                        <%= submit_tag "Save note", name: "action_status", value: "open", class: "primary-button secondary" %>
                        <%= submit_tag "Mark done", name: "action_status", value: "completed", class: "primary-button" %>
                      </div>
                    </div>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% end %>
        </section>
      <% end %>
    </div>
  </main>
</div>
