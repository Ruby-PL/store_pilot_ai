# Local service ports. Change these if the defaults are already in use.
POSTGRES_PORT=5432
REDIS_PORT=6379

# Local PostgreSQL credentials used by Docker Compose.
POSTGRES_USER=store_pilot_ai
POSTGRES_PASSWORD=store_pilot_ai

# Rails connection URLs. bin/setup supplies these defaults automatically.
DATABASE_URL=postgresql://store_pilot_ai:store_pilot_ai@127.0.0.1:5432/store_pilot_ai_development
REDIS_URL=redis://127.0.0.1:6379/0

# Rails server port.
PORT=3005

# Solid Queue worker process concurrency.
JOB_CONCURRENCY=1

# Public host used by deployed environments.
APP_HOST=staging.storepilot.example

# Shopify Partner app configuration.
# SHOPIFY_API_KEY is the public client ID from the Shopify Dev Dashboard.
# Never commit the real SHOPIFY_API_SECRET value.
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=http://localhost:3005
SHOPIFY_REDIRECT_URI=http://localhost:3005/auth/shopify/callback
SHOPIFY_SCOPES=read_products,write_products,read_orders
SHOPIFY_API_VERSION=2026-04
SHOPIFY_REQUIRE_CREDENTIALS=false

# Production deployment placeholders. Do not put real production values in this
# file; provide them through your shell, password manager, or Kamal secrets.
# Production URL: https://app.storepilot.ai
# APPLICATION_HOST=app.storepilot.ai
# KAMAL_APP_HOST=app.storepilot.ai
# KAMAL_WEB_HOST=app.storepilot.ai
# KAMAL_JOB_HOST=app.storepilot.ai
# JOB_CONCURRENCY=1
# PRODUCTION_SHOPIFY_API_KEY=production_client_id
# PRODUCTION_SHOPIFY_API_SECRET=production_client_secret
# SHOPIFY_API_KEY=${PRODUCTION_SHOPIFY_API_KEY}
# SHOPIFY_API_SECRET=${PRODUCTION_SHOPIFY_API_SECRET}
# SHOPIFY_APP_URL=https://app.storepilot.ai
# SHOPIFY_REDIRECT_URI=https://app.storepilot.ai/auth/shopify/callback
# SHOPIFY_SCOPES=read_products,read_orders
# SHOPIFY_REQUIRE_CREDENTIALS=true
# KAMAL_REGISTRY_PASSWORD=
# RAILS_MASTER_KEY=
# PRODUCTION_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME
# DATABASE_URL=${PRODUCTION_DATABASE_URL}
# CACHE_DATABASE_URL=
# QUEUE_DATABASE_URL=
# CABLE_DATABASE_URL=
# REDIS_URL=rediss://USER:PASSWORD@HOST:6379/0
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=staging
# SENTRY_RELEASE=
# SENTRY_TRACES_SAMPLE_RATE=0
# RESEND_API_KEY=
# MAILER_FROM=StorePilot <noreply@storepilot.ai>
# RESEND_SMTP_ADDRESS=smtp.resend.com
# RESEND_SMTP_PORT=587
# RESEND_SMTP_USERNAME=resend
