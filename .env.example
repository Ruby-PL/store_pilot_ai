# Local service ports. Change these if the defaults are already in use.
POSTGRES_PORT=5432
REDIS_PORT=6379

# Local PostgreSQL credentials used by Docker Compose.
POSTGRES_USER=store_pilot_ai
POSTGRES_PASSWORD=store_pilot_ai

# Rails connection URLs. bin/setup supplies these defaults automatically.
DATABASE_URL=postgresql://store_pilot_ai:store_pilot_ai@127.0.0.1:5432/store_pilot_ai_development
REDIS_URL=redis://127.0.0.1:6379/0

# Rails server port.
PORT=3000
